generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Product {
  id                String   @id @default(uuid())
  name              String
  description       String?   // 新增：整體商品簡介
  ingredients       String?   // 新增：成分材質
  tags              String[]  @default([]) // 人工搜尋關鍵字
  pitch             String?   // 一句話定位
  coreSellingPoints String // 核心賣點
  problemsSolved    String // 適合解決的問題
  targetAudience    String // 適合推薦的對象
  salesTips         String // 怎麼賣、建議從哪個角度推薦
  bossNotes         String // 老闆或內部補充說明，承接商品 DNA
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  replies      Reply[]
  assets       Asset[]
  inquiryCases InquiryCase[]
}

model Reply {
  id        String   @id @default(uuid())
  productId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  content   String
  scenario  String // 對應情境
  note      String? // 內部備註、語氣等
  isPremium Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt // 依需求補上
}

model Asset {
  id        String   @id @default(uuid())
  productId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  type      String // product_img, testimonial_img, scenario_img, video_link, official_url
  title     String // 素材名稱
  url       String // 連接
  note      String? // 適合怎麼用
  sortOrder Int      @default(0) // 顯示排序
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt // 依需求補上
}

model InquiryCase {
  id                 String   @id @default(uuid())
  queryContent       String   @db.Text // 原始客訴或情境描述
  analysis           String?  @db.Text // 痛點分析與關鍵字
  suggestedProductId String? // 推薦的解決方案商品
  product            Product? @relation(fields: [suggestedProductId], references: [id], onDelete: SetNull)
  finalReply         String?  @db.Text // 最終敲定的回覆草稿
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}
